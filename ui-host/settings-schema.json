{
  "groups": [
    {
      "key": "basic",
      "name": "基础设置",
      "groups": [
        {
          "key": "model",
          "name": "模型",
          "options": [
            {
              "key": "model_name",
              "name": "模型名称",
              "type": "combobox",
              "default": "qwen3-asr-0.6b"
            },
            {
              "key": "download_0.6b",
              "name": "Qwen3-ASR-0.6B",
              "type": "modeldownload",
              "default": ""
            },
            {
              "key": "download_1.7b",
              "name": "Qwen3-ASR-1.7B",
              "type": "modeldownload",
              "default": ""
            },
            {
              "key": "mirror",
              "name": "下载源",
              "type": "combobox",
              "default": "hf-mirror"
            }
          ]
        },
        {
          "key": "recognition",
          "name": "识别选项",
          "options": [
            {
              "key": "language",
              "name": "识别语言",
              "type": "combobox",
              "default": "Chinese"
            },
            {
              "key": "stream_transcription",
              "text": "启用流式输入",
              "type": "checkbox",
              "default": true
            }
          ]
        },
        {
          "key": "recording",
          "name": "录音",
          "options": [
            {
              "key": "source",
              "name": "麦克风输入",
              "type": "combobox",
              "default": ""
            },
            {
              "key": "min_record_seconds",
              "name": "最短录音时间（秒）",
              "type": "lineedit",
              "default": "0.25"
            },
            {
              "key": "rate",
              "name": "采样率（Hz）",
              "type": "combobox",
              "default": 16000
            },
            {
              "key": "channels",
              "name": "声道数",
              "type": "combobox",
              "default": 1
            },
            {
              "key": "format",
              "name": "采样格式",
              "type": "combobox",
              "default": "s16"
            }
          ]
        }
      ]
    },
    {
      "key": "advanced",
      "name": "高级设置",
      "groups": [
        {
          "key": "runtime",
          "name": "运行环境",
          "options": [
            {
              "key": "asr_timeout_seconds",
              "name": "识别超时（秒）",
              "type": "spinbutton",
              "default": 120,
              "min": 10,
              "max": 3600,
              "step": 10
            }
          ]
        },
        {
          "key": "fcitx",
          "name": "Fcitx",
          "options": [
            {
              "key": "fcitx_commit",
              "text": "启用 Fcitx 上屏",
              "type": "checkbox",
              "default": true
            }
          ]
        },
        {
          "key": "storage",
          "name": "存储",
          "options": [
            {
              "key": "recordings_dir",
              "name": "录音保存目录",
              "type": "lineedit",
              "default": "$HOME/.local/share/echoflow/recordings"
            },
            {
              "key": "save_live_debug_audio",
              "text": "保存流式录音调试文件",
              "type": "checkbox",
              "default": false
            }
          ]
        }
      ]
    }
  ]
}
