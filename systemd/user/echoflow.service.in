[Unit]
Description=EchoFlow offline voice input service
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/echoflow
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/echoflow-service
Restart=on-failure

[Install]
WantedBy=default.target
